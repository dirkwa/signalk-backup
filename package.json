{
  "name": "signalk-backup",
  "version": "0.1.0",
  "description": "Scheduled deduplicated backups of SignalK config to local storage and Google Drive (via Kopia + rclone)",
  "main": "plugin/index.js",
  "type": "module",
  "signalk-plugin-enabled-by-default": true,
  "scripts": {
    "format": "prettier --write 'src/**/*.ts' 'test/**/*.ts' && eslint --fix 'src/**/*.ts' 'test/**/*.ts'",
    "lint": "eslint 'src/**/*.ts' 'test/**/*.ts'",
    "build": "tsc",
    "build:all": "npm run lint && npm run build && npm run test",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "signalk-node-server-plugin",
    "signalk-category-utility",
    "backup",
    "kopia",
    "rclone",
    "google-drive"
  ],
  "signalk": {
    "displayName": "Backup",
    "appIcon": "assets/icon.png",
    "requires": [
      "signalk-container"
    ]
  },
  "files": [
    "plugin/**/*",
    "assets/**/*",
    "docs/**/*"
  ],
  "engines": {
    "node": ">=22.5.0",
    "signalk": ">=2.24.0"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.0"
  },
  "peerDependencies": {
    "signalk-container": ">=0.1.6"
  },
  "peerDependenciesMeta": {
    "signalk-container": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@signalk/server-api": "^2.24.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "prettier": "^3.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.1.5"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dirkwa/signalk-backup.git"
  },
  "license": "Apache-2.0"
}
