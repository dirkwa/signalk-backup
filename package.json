{
  "name": "signalk-backup",
  "version": "0.8.0",
  "description": "Scheduled deduplicated backups of SignalK config to local storage and Google Drive (via Kopia + rclone)",
  "main": "plugin/index.js",
  "type": "module",
  "signalk-plugin-enabled-by-default": true,
  "scripts": {
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\" \"webapp/**/*.{ts,tsx,html}\" && eslint --fix \"src/**/*.ts\" \"test/**/*.ts\" \"webapp/**/*.{ts,tsx}\"",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\" \"webapp/**/*.{ts,tsx}\"",
    "typecheck:webapp": "tsc -p tsconfig.webapp.json",
    "build:plugin": "tsc",
    "build:webapp": "vite build",
    "build": "npm run build:plugin && npm run typecheck:webapp && npm run build:webapp",
    "build:all": "npm run lint && npm run build && npm run test",
    "dev": "vite",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "signalk-node-server-plugin",
    "signalk-embeddable-webapp",
    "signalk-category-utility",
    "backup",
    "kopia",
    "rclone",
    "google-drive"
  ],
  "signalk": {
    "displayName": "Backup",
    "appIcon": "icon.svg",
    "screenshots": [
      "./docs/screenshots/1_signalk-backup_dashboard.png",
      "./docs/screenshots/2_signalk-backup_backups.png",
      "./docs/screenshots/3_signalk-backup_browse.png",
      "./docs/screenshots/4_signalk-backup_database-exports.png",
      "./docs/screenshots/5_signalk-backup_cloud-sync.png",
      "./docs/screenshots/6_signalk-backup_settings.png"
    ],
    "requires": [
      "signalk-container"
    ]
  },
  "files": [
    "plugin/**/*",
    "public/**/*",
    "assets/**/*",
    "docs/**/*"
  ],
  "engines": {
    "node": ">=22.5.0",
    "signalk": ">=2.24.0"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.0",
    "bonjour-service": "~1.4.0",
    "unzipper": "^0.12.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@module-federation/vite": "^1.15.0",
    "@signalk/server-admin-ui-dependencies": "^2.23.0",
    "@signalk/server-api": "^2.24.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "@types/unzipper": "^0.10.11",
    "@vitejs/plugin-react": "^6.0.1",
    "bootstrap": "^5.3.8",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "express": "^5.2.1",
    "prettier": "^3.0.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "reactstrap": "^9.2.3",
    "supertest": "^7.2.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.0.0",
    "vite": "^8.0.11",
    "vitest": "^4.1.5"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dirkwa/signalk-backup.git"
  },
  "license": "Apache-2.0"
}
